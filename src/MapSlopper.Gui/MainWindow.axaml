<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MapSlopper.Gui"
        x:Class="MapSlopper.Gui.MainWindow"
        Width="1200" Height="800"
        Title="MapSlopper"
        Background="#1A1A1F">
    <Window.Styles>
        <Style Selector="Button.tool">
            <Setter Property="Background" Value="#2A2A30" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="BorderBrush" Value="#3A3A42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="2,1" />
        </Style>
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A45" />
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="Button.tool.active">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1F8FE6" />
        </Style>
        <Style Selector="Button.tool.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
    </Window.Styles>
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Name="MenuNew" Header="_New" InputGesture="Ctrl+N" />
                <MenuItem Name="MenuOpen" Header="_Open..." InputGesture="Ctrl+O" />
                <MenuItem Name="MenuSave" Header="_Save" InputGesture="Ctrl+S" />
                <MenuItem Name="MenuSaveAs" Header="Save _As..." InputGesture="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Name="MenuExport" Header="_Export .map..." InputGesture="Ctrl+E" />
                <Separator />
                <MenuItem Name="MenuExit" Header="E_xit" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Name="MenuUndo" Header="_Undo" InputGesture="Ctrl+Z" />
                <MenuItem Name="MenuRedo" Header="_Redo" InputGesture="Ctrl+Y" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MenuLevels" Header="_Levels..." />
                <MenuItem Name="MenuFrame" Header="_Frame Project" InputGesture="F" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Name="MenuAbout" Header="_About" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Background="#222" Padding="6,3">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Name="StatusText" Text="Ready." Foreground="#DDD" />
                <TextBlock Grid.Column="1" Name="UndoState" Text="Undo:0 Redo:0" Foreground="#AAA" Margin="12,0" />
                <TextBlock Grid.Column="2" Name="ClosedState" Text="Closed: no" Foreground="#AAA" Margin="12,0" />
                <TextBlock Grid.Column="3" Text="MapSlopper" Foreground="#666" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" MinWidth="40" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="220" MinWidth="40" />
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" Background="#181820"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="0">
                    <TextBlock Text="Tools" Foreground="#888" Margin="8,8,8,4" FontWeight="Bold" />
                    <Button Name="ToolBtn1" Classes="tool" Content="1: Add Point" />
                    <Button Name="ToolBtn2" Classes="tool" Content="2: Insert Edge" />
                    <Button Name="ToolBtn3" Classes="tool" Content="3: Move Point" />
                    <Button Name="ToolBtn4" Classes="tool" Content="4: Erase Edge" />
                    <Button Name="ToolBtn5" Classes="tool" Content="5: Connect" />
                    <Button Name="ToolBtn6" Classes="tool" Content="6: Remove Point" />
                    <Button Name="ToolBtn7" Classes="tool" Content="7: Height Brush" />
                    <Button Name="ToolBtn8" Classes="tool" Content="8: Trigger Brush" />
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Background="#2A2A30"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns" />

            <TabControl Grid.Column="2">
                <TabItem Header="2D Editor">
                    <local:Editor2DControl Name="Canvas" />
                </TabItem>
                <TabItem Header="3D Preview">
                    <local:Preview3DControl Name="Preview3D" />
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Background="#2A2A30"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns" />

            <ScrollViewer Grid.Column="4" Background="#181820"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <StackPanel Spacing="6">
                    <TextBlock Text="Active Tool" Foreground="#888" />
                    <TextBlock Name="ActiveToolText" Text="Add Point" Foreground="#DDD" FontWeight="Bold" />
                    <Separator />
                    <TextBlock Text="Brush size (cells)" Foreground="#888" />
                    <NumericUpDown Name="BrushSize" Minimum="1" Maximum="64" Value="1" Increment="1" />
                    <TextBlock Text="Paint value (Quake units, 0..65535)" Foreground="#888" />
                    <NumericUpDown Name="PaintValue" Minimum="0" Maximum="65535" Value="64" Increment="16" />
                    <local:HeightHistogramControl Name="HeightHistogram" Height="80" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,0">
                        <TextBlock Grid.Column="0" Text="Lo" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <Slider Grid.Column="1" Name="LevelsMinSlider" Minimum="0" Maximum="65535" />
                        <TextBlock Grid.Column="2" Name="LevelsMinText" Foreground="#DDD" VerticalAlignment="Center" Width="48" TextAlignment="Right" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="Hi" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <Slider Grid.Column="1" Name="LevelsMaxSlider" Minimum="0" Maximum="65535" />
                        <TextBlock Grid.Column="2" Name="LevelsMaxText" Foreground="#DDD" VerticalAlignment="Center" Width="48" TextAlignment="Right" />
                    </Grid>
                    <TextBlock Text="Floor top Z = paint value. Auto-clamped to (ceilingHeight - 8) at export." Foreground="#666" TextWrapping="Wrap" FontSize="11" />
                    <Separator />
                    <CheckBox Name="SnapCheck" Content="Snap Move to grid (G / Shift)" Foreground="#DDD" />
                    <Separator />
                    <TextBlock Name="TriggerPaletteHeader" Text="Trigger palette" Foreground="#888" />
                    <StackPanel Name="TriggerPalette" Spacing="3" />
                    <Separator />
                    <TextBlock Name="CursorText" Text="Cursor: -" Foreground="#AAA" />
                    <TextBlock Name="ToolHintText" Text="" Foreground="#9CB" TextWrapping="Wrap" FontSize="11" />
                    <TextBlock Text="Tip: middle-drag or Space+drag to pan, wheel to zoom. Esc resets the active tool's chain." Foreground="#666" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
