<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MapSlopper.Gui"
        x:Class="MapSlopper.Gui.MainWindow"
        Width="1200" Height="800"
        Title="MapSlopper"
        Background="#1A1A1F">
    <Window.Styles>
        <Style Selector="Button.tool">
            <Setter Property="Background" Value="#2A2A30" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="BorderBrush" Value="#3A3A42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="2,1" />
        </Style>
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A45" />
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="Button.tool.active">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1F8FE6" />
        </Style>
        <Style Selector="Button.tool.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
    </Window.Styles>
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Name="MenuNew" Header="_New" InputGesture="Ctrl+N" />
                <MenuItem Name="MenuOpen" Header="_Open..." InputGesture="Ctrl+O" />
                <MenuItem Name="MenuSave" Header="_Save" InputGesture="Ctrl+S" />
                <MenuItem Name="MenuSaveAs" Header="Save _As..." InputGesture="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Name="MenuExport" Header="_Export .map..." InputGesture="Ctrl+E" />
                <Separator />
                <MenuItem Name="MenuExit" Header="E_xit" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Name="MenuUndo" Header="_Undo" InputGesture="Ctrl+Z" />
                <MenuItem Name="MenuRedo" Header="_Redo" InputGesture="Ctrl+Y" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MenuLevels" Header="_Levels..." />
                <MenuItem Name="MenuFrame" Header="_Frame Project" InputGesture="F" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Name="MenuAbout" Header="_About" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Background="#222" Padding="6,3">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Name="StatusText" Text="Ready." Foreground="#DDD" />
                <TextBlock Grid.Column="1" Name="UndoState" Text="Undo:0 Redo:0" Foreground="#AAA" Margin="12,0" />
                <TextBlock Grid.Column="2" Name="ClosedState" Text="Closed: no" Foreground="#AAA" Margin="12,0" />
                <TextBlock Grid.Column="3" Text="MapSlopper" Foreground="#666" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Left" Width="140" Background="#181820" Spacing="0">
            <TextBlock Text="Tools" Foreground="#888" Margin="8,8,8,4" FontWeight="Bold" />
            <Button Name="ToolBtn1" Classes="tool" Content="1: Add Point" />
            <Button Name="ToolBtn2" Classes="tool" Content="2: Insert Edge" />
            <Button Name="ToolBtn3" Classes="tool" Content="3: Move Point" />
            <Button Name="ToolBtn4" Classes="tool" Content="4: Erase Edge" />
            <Button Name="ToolBtn5" Classes="tool" Content="5: Connect" />
            <Button Name="ToolBtn6" Classes="tool" Content="6: Remove Point" />
            <Button Name="ToolBtn7" Classes="tool" Content="7: Height Brush" />
        </StackPanel>

        <Border DockPanel.Dock="Right" Width="220" Background="#181820" Padding="8">
            <StackPanel Spacing="6">
                <TextBlock Text="Active Tool" Foreground="#888" />
                <TextBlock Name="ActiveToolText" Text="Add Point" Foreground="#DDD" FontWeight="Bold" />
                <Separator />
                <TextBlock Text="Brush size (cells)" Foreground="#888" />
                <NumericUpDown Name="BrushSize" Minimum="1" Maximum="64" Value="1" Increment="1" />
                <TextBlock Text="Paint value (Quake units)" Foreground="#888" />
                <NumericUpDown Name="PaintValue" Minimum="0" Maximum="2040" Value="64" Increment="16" />
                <TextBlock Text="Floor top Z = paint value. Keep below ceilingHeight (default 256)." Foreground="#666" TextWrapping="Wrap" FontSize="11" />
                <Separator />
                <TextBlock Name="CursorText" Text="Cursor: -" Foreground="#AAA" />
                <TextBlock Text="Tip: middle-drag or Space+drag to pan, wheel to zoom." Foreground="#666" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TabControl>
            <TabItem Header="2D Editor">
                <local:Editor2DControl Name="Canvas" />
            </TabItem>
            <TabItem Header="3D Preview">
                <local:Preview3DControl Name="Preview3D" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
